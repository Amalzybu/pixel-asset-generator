{
  "name": "pixel-asset-generator",
  "version": "0.6.0",
  "description": "A desktop tool for game developers to generate pixel-art assets and sprites",
  "main": "electron/main.js",
  "scripts": {
    "gui": "electron .",
    "gui:dev": "electron . --inspect",
    "cli": "node src/cli.js"
  },
  "keywords": ["pixel-art", "sprite", "game-dev", "procedural-generation", "tileset", "electron"],
  "license": "MIT",
  "dependencies": {
    "canvas": "^2.11.2",
    "gif-encoder-2": "^1.0.5",
    "pngjs": "^7.0.0",
    "sharp": "^0.33.0",
    "simplex-noise": "^4.0.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "electron": "^29.0.0"
  }
}
